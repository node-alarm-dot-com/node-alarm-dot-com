{
  "name": "node-alarm-dot-com",
  "version": "2.4.0",
  "description": "An interface module written in node.js to arm and disarm Alarm.com security systems.",
  "author": {
    "name": "Chase Christiansen",
    "url": "https://github.com/chase9"
  },
  "license": "MIT",
  "keywords": [
    "node-only",
    "security",
    "alarm",
    "alarm.com",
    "alarm-dot-com",
    "alarmdotcom",
    "frontpoint",
    "homekit",
    "homebridge",
    "homebridge-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/node-alarm-dot-com/node-alarm-dot-com.git"
  },
  "homepage": "https://github.com/node-alarm-dot-com/node-alarm-dot-com#readme",
  "bugs": {
    "url": "https://github.com/node-alarm-dot-com/node-alarm-dot-com/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "nodeADC": "dist/index.js"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "lint": "eslint src/**.ts",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "postpublish": "npm run clean",
    "start": "ts-node src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "yargs": "^18.0.0"
  }
}
